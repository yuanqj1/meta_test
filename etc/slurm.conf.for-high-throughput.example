#
# Example slurm.conf file for high throughput. Please run configurator.html
# (in doc/html) to build a configuration file customized
# for your environment.
#
#
# slurm.conf file generated by configurator.html.
# Put this file on all nodes of your cluster.
# See the slurm.conf man page for more information.
#
#
#
ControlMachine=admin01
ControlAddr=
AccountingStorageHost=admin01
ClusterName=high_throughput_test
AuthType=auth/munge
CryptoType=crypto/munge
EnforcePartLimits=NO
FirstJobId=10000
MaxJobId=536805376
GroupUpdateForce=1
GroupUpdateTime=600
JobRequeue=0
KillOnBadExit=1
MaxArraySize=50000
MaxJobCount=3500000
MpiDefault=none
PrologFlags=CONTAIN
ReturnToService=2
SlurmctldPidFile=/var/run/slurmctld.pid
SlurmctldPort=10650-10700
SlurmdPidFile=/var/run/slurmd.%n.pid
SlurmdPort=10900
SlurmdSpoolDir=/opt/gridview/slurm/spool_slurmd_%n
SlurmUser=root
StateSaveLocation=/opt/gridview/slurm/spool
SwitchType=switch/none
TreeWidth=120
RoutePlugin=route/default
BatchStartTimeout=600
TCPTimeout=3
InactiveLimit=0
KillWait=30
MessageTimeout=60
MinJobAge=3
SlurmctldTimeout=180
SlurmdTimeout=600
UnkillableStepTimeout=300
Waittime=0
EioTimeout=300
SchedulerType=sched/builtin
SelectType=select/cons_tres
SelectTypeParameters=CR_CORE
SchedulerParameters=defer_batch,sched_min_interval=150000,sched_interval=120,max_sched_time=2,default_queue_depth=800,partition_job_depth=800,enable_high_throughput,para_sched
SlurmctldParameters=enable_stepmgr,enable_rpc_queue,rpc_queue_pool_size=10,para_submit,para_epilog,agent_thread_pool_size=64,no_step_complete_throttle,ignore_srun_job_complete,buf_pool_size=200,job_pool_size=200
SchedulerTimeSlice=30
AllowSpecResourcesUsage=No
PriorityType=priority/basic
AccountingStorageEnforce=nosteps
AccountingStoragePort=10031
AccountingStorageType=accounting_storage/slurmdbd
AccountingStorageUser=root
AcctGatherNodeFreq=0
JobAcctGatherType=jobacct_gather/none
SlurmctldDebug=2
SlurmctldLogFile=/opt/gridview/slurm/log/slurmctld.log
SlurmdDebug=6
SlurmdLogFile=/opt/gridview/slurm/log/slurmd_%n.log
DebugFlags=NO_CONF_HASH
DefMemPerCPU=1000

# COMPUTE NODES
# IF NOT MULTIPLE SLURMD, DELETE PORT IN NODE CONF
NodeName=noder1n[00-19] State=UNKNOWN CPUs=32 NodeAddr=xx Port=17021 Boards=1 SocketsPerBoard=4 CoresPerSocket=8 ThreadsPerCore=1 RealMemory=126500 MemSpecLimit=10240
NodeName=noder3n[00-19] State=UNKNOWN CPUs=32 NodeAddr=xx Port=17022 Boards=1 SocketsPerBoard=4 CoresPerSocket=8 ThreadsPerCore=1 RealMemory=126500 MemSpecLimit=10240

PartitionName=debug AllowAccounts=ALL Default=YES DefaultTime=01:00:00 Nodes=ALL  State=up